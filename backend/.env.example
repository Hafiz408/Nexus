# Nexus — environment configuration
# Copy to backend/.env and fill in your values
# ---------------------------------------------------------------------------

# PostgreSQL (required)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Provider selection
# Type: str | Options: mistral | openai | Default: mistral
EMBEDDING_PROVIDER=mistral
LLM_PROVIDER=mistral

# API keys (provide the key for your chosen provider)
MISTRAL_API_KEY=
OPENAI_API_KEY=

# LLM model name (interpreted by the active LLM_PROVIDER)
# Type: str | Default: mistral-small-latest
MODEL_NAME=mistral-small-latest

# LangSmith tracing (optional — Phase 9+)
LANGCHAIN_API_KEY=
# Type: bool | Default: false
LANGCHAIN_TRACING_V2=false
# Type: str | Default: nexus-v1
LANGCHAIN_PROJECT=nexus-v1


# ---------------------------------------------------------------------------
# V2 Agent Tuning
# ---------------------------------------------------------------------------

# GitHub personal access token — required for GitHub MCP PR comments (MCP-01)
# Leave empty to disable GitHub MCP (silently skipped when no token is set)
# Type: str | Default: (empty = disabled)
GITHUB_TOKEN=

# Maximum critic retry loops before forcing output regardless of score (CRIT-02, CRIT-03)
# Hard cap enforced in Critic agent — value of 2 matches the required maximum
# Type: int | Default: 2 | Range: 1–N
MAX_CRITIC_LOOPS=2

# Critic quality gate threshold — score below this triggers a retry loop (CRIT-02)
# Score is computed as 0.4×groundedness + 0.35×relevance + 0.25×actionability
# Type: float | Default: 0.7 | Range: 0.0–1.0
CRITIC_THRESHOLD=0.7

# Maximum forward call graph traversal hops in the Debugger agent (DBUG-01)
# Type: int | Default: 4 | Range: 1–N
DEBUGGER_MAX_HOPS=4

# Context hop radius for the Reviewer agent — 1 = direct callers + callees only (REVW-01)
# Type: int | Default: 1 | Range: 1–N
REVIEWER_CONTEXT_HOPS=1
