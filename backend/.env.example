# Nexus backend environment — copy to .env and fill in your values
# Used only for local dev (Option B). Extension users configure via VS Code settings.

# ── Providers ─────────────────────────────────────────────────────────────────
# Supported: mistral | openai | anthropic | ollama | gemini
LLM_PROVIDER=mistral
EMBEDDING_PROVIDER=mistral

# ── API Keys ──────────────────────────────────────────────────────────────────
# If LLM_PROVIDER and EMBEDDING_PROVIDER are the same, both can share one key.
LLM_PROVIDER_API_KEY=your_key_here
EMBEDDING_PROVIDER_API_KEY=your_key_here   # same as above if providers match

# ── GitHub (optional — enables "Post to PR" in Review mode) ───────────────────
# GITHUB_TOKEN=ghp_...

# ── Ollama (optional — only needed when provider is ollama) ───────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=nexus-v4

# ── Agent tuning (optional — safe defaults shown) ────────────────────────────
# MAX_CRITIC_LOOPS=2
# CRITIC_THRESHOLD=0.7
# DEBUGGER_MAX_HOPS=4
# REVIEWER_CONTEXT_HOPS=1
