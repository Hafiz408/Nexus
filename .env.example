# PostgreSQL
# Inside Docker: POSTGRES_HOST=postgres, POSTGRES_PORT=5432
# Local dev:     POSTGRES_HOST=localhost, POSTGRES_PORT=5432
POSTGRES_USER=nexus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nexus_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Mistral API (required for embeddings + LLM)
MISTRAL_API_KEY=your-mistral-api-key

# OpenAI (optional — only needed for RAGAS evaluation)
OPENAI_API_KEY=

# LangSmith (optional — Phase 9+ tracing)
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=nexus-v1
